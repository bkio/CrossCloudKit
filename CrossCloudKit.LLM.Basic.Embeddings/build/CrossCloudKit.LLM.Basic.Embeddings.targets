<Project>
  <!--
    Copy the bundled GGUF embedding model to the consuming project's output directory.
    $(MSBuildThisFileDirectory)../ resolves to the NuGet package root at restore time.
  -->
  <ItemGroup>
    <Content Include="$(MSBuildThisFileDirectory)..\content\models\snowflake-arctic-embed-m-long-Q8_0.gguf"
             Condition="Exists('$(MSBuildThisFileDirectory)..\content\models\snowflake-arctic-embed-m-long-Q8_0.gguf')"
             CopyToOutputDirectory="PreserveNewest"
             Link="models\snowflake-arctic-embed-m-long-Q8_0.gguf"
             TargetPath="models\snowflake-arctic-embed-m-long-Q8_0.gguf" />
  </ItemGroup>

  <!--
    LLamaSharp.Backend.Cpu delivers native libraries (libllama, libggml, etc.) via
    build/ props that only apply to direct consumers. Import them here so direct
    NuGet consumers of this package also get the native libs.
    The guard property prevents a duplicate-import warning when both Embeddings and
    Completion packages are referenced in the same project.
  -->
  <Import Project="$(NuGetPackageRoot)llamasharp.backend.cpu/0.26.0/build/netstandard2.0/LLamaSharp.Backend.Cpu.props"
          Condition="'$(_LLamaSharpBackendCpuImported)' != 'true' AND Exists('$(NuGetPackageRoot)llamasharp.backend.cpu/0.26.0/build/netstandard2.0/LLamaSharp.Backend.Cpu.props')" />
  <PropertyGroup>
    <_LLamaSharpBackendCpuImported>true</_LLamaSharpBackendCpuImported>
  </PropertyGroup>
</Project>
